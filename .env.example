# Database (Supabase)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="your_secret_here"
JWT_EXPIRES_TIME="30m"
JWT_REFRESH_SECRET="your_refresh_secret_here"
JWT_REFRESH_EXPIRES_TIME="7d"

# Gemini API Key
GEMINI_API_KEY="your_gemini_key_here"

# Môi trường chạy
PORT=3000

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# OpenRouter (AI Fallback, ví dụ dùng Free Tier của NVIDIA hay Google)
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_MODEL="nvidia/nemotron-3-super-120b-a12b:free"

# Supabase Storage & Config
SUPABASE_PROJECT_ID="your_supabase_project_id"
SUPABASE_PROJECT_URL="https://[YOUR_PROJECT_ID].supabase.co"
SUPABASE_PUBLISHABLE_KEY="your_publishable_api_key"
SUPABASE_ANON_KEY="your_anon_key"
SUPABASE_SECRET_KEY="your_service_role_secret_key"
SUPABASE_STORAGE_BUCKET="ats_storage"

# Hệ Thống Gửi Email (Ví dụ dùng App Password của Gmail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER="your-email@gmail.com"
MAIL_PASS="your-email-app-password"
MAIL_FROM="ATS System <no-reply@ats.com>"

# URL Frontend dùng để nhúng vào Email (ví dụ link reset pass)
APP_URL="http://localhost:3000"
